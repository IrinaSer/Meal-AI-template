<?xml version="1.0" encoding="UTF-8"?>
<!--
  Meal-AI — launchd-агент фоновой обработки инбокса (Фаза B).

  УСТАНОВКА (выполнить ПОСЛЕ установки Яндекс.Диска и проверки INBOX_PATH):
    # Подставить свой путь к проекту вместо плейсхолдера __PROJECT_DIR__:
    sed "s#__PROJECT_DIR__#$(pwd)#g" scripts/com.meal-ai.inbox.plist \
      > ~/Library/LaunchAgents/com.meal-ai.inbox.plist
    launchctl load ~/Library/LaunchAgents/com.meal-ai.inbox.plist
  ОСТАНОВКА:
    launchctl unload ~/Library/LaunchAgents/com.meal-ai.inbox.plist

  Запускает scripts/process-inbox.sh каждые 900 секунд (15 минут).
  (Команду sed выполнять из корня проекта.)
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.meal-ai.inbox</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_DIR__/scripts/process-inbox.sh</string>
    </array>

    <key>StartInterval</key>
    <integer>900</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/scripts/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/scripts/launchd.err.log</string>
</dict>
</plist>

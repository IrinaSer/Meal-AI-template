<?xml version="1.0" encoding="UTF-8"?>
<!--
  Meal-AI — launchd-агент еженедельного дайджеста.

  УСТАНОВКА (из корня проекта):
    # Подставить свой путь к проекту вместо плейсхолдера __PROJECT_DIR__:
    sed "s#__PROJECT_DIR__#$(pwd)#g" scripts/com.meal-ai.weekly.plist \
      > ~/Library/LaunchAgents/com.meal-ai.weekly.plist
    launchctl load ~/Library/LaunchAgents/com.meal-ai.weekly.plist
  ОСТАНОВКА:
    launchctl unload ~/Library/LaunchAgents/com.meal-ai.weekly.plist

  Запускает scripts/weekly-digest.sh по воскресеньям в 20:00 (если Мак спал —
  launchd выполнит при ближайшем пробуждении). Скрипт идемпотентен за неделю.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.meal-ai.weekly</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_DIR__/scripts/weekly-digest.sh</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>0</integer>
        <key>Hour</key>
        <integer>20</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/scripts/weekly.out.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/scripts/weekly.err.log</string>
</dict>
</plist>

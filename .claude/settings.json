{
  "permissions": {
    "allow": [
      "Read(~/Yandex.Disk.localized/Meal-AI-Inbox/**)",
      "Edit(~/Yandex.Disk.localized/Meal-AI-Inbox/**)",
      "Write(~/Yandex.Disk.localized/Meal-AI-Inbox/**)",
      "Edit(data/**)",
      "Write(data/**)",
      "Bash(jq:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(date:*)",
      "Bash(scripts/render-diary.sh:*)",
      "Bash(bash scripts/render-diary.sh:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/scripts/session-welcome.sh\"",
            "timeout": 10,
            "statusMessage": "Приветствие Meal-AI"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/scripts/statusline.sh\"",
    "padding": 0
  },
  "spinnerVerbs": {
    "mode": "append",
    "verbs": [
      "Взвешиваю",
      "Считаю БЖУ",
      "Сверяюсь с foods.csv",
      "Раскладываю по тарелке",
      "Прикидываю порцию",
      "Листаю дневник"
    ]
  }
}
